<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D">

    <!-- SETUP EKRANI -->
    <LinearLayout
        android:id="@+id/setup_screen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="60dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TV WebApp"
            android:textColor="#FFFFFF"
            android:textSize="36sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sayt manzilingizni kiriting"
            android:textColor="#AAAAAA"
            android:textSize="20sp"
            android:layout_marginBottom="40dp"/>

        <EditText
            android:id="@+id/url_input"
            android:layout_width="520dp"
            android:layout_height="64dp"
            android:background="@drawable/input_bg"
            android:textColor="#FFFFFF"
            android:textColorHint="#555555"
            android:textSize="18sp"
            android:hint="https://example.com"
            android:inputType="textUri"
            android:imeOptions="actionGo"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:singleLine="true"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tv_error"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF5555"
            android:textSize="15sp"
            android:layout_marginBottom="16dp"
            android:visibility="gone"/>

        <Button
            android:id="@+id/btn_save"
            android:layout_width="520dp"
            android:layout_height="60dp"
            android:text="Saqlash va Boshlash"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/button_bg"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:layout_width="520dp"
            android:layout_height="wrap_content"
            android:text="Manzilni keyinchalik o&#39;zgartirish uchun: Sozlamalar → Ilovalar → TV WebApp → Ma&#39;lumotlarni tozalash"
            android:textColor="#444444"
            android:textSize="13sp"
            android:gravity="center"/>

    </LinearLayout>

    <!-- WEBVIEW EKRANI -->
    <RelativeLayout
        android:id="@+id/webview_screen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <WebView
            android:id="@+id/webview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:focusable="true"
            android:focusableInTouchMode="true"/>

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_alignParentTop="true"
            android:max="100"
            android:progressTint="#E53935"
            android:visibility="gone"/>

    </RelativeLayout>

</FrameLayout>
